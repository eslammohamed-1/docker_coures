      "timestamps": {
        "from": "00:04:12,900",
        "to": "00:04:21,220"
      },
      "offsets": {
        "from": 252900,
        "to": 261220
      },
      "text": "يساوي الـ Application. فلو أنت قفلت الـ Application دي،"
