    {
      "timestamps": {
        "from": "00:02:59,460",
        "to": "00:03:04,260"
      },
      "offsets": {
        "from": 179460,
        "to": 184260
      },
      "text": "ممكن تنزلها سواء محتاجها لنفس الحاجة دي أو مش محتاجها."
