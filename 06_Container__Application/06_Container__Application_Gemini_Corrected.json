    {
      "timestamps": {
        "from": "00:03:21,280",
        "to": "00:03:30,220"
      },
      "offsets": {
        "from": 201280,
        "to": 210220
      },
      "text": "حاجة موجودة جواها. فيها نظام كامل نزل عندك بالكامل."
    },
    {
      "timestamps": {
        "from": "00:03:30,220",
        "to": "00:03:33,940"
      },
      "offsets": {
        "from": 210220,
        "to": 213940
      },
      "text": "نزل عندك بالكامل. فأنا ممكن أفتح وما استعملش حتى اللي أنا"
