    {
      "timestamps": {
        "from": "00:03:49,420",
        "to": "00:03:52,360"
      },
      "offsets": {
        "from": 229420,
        "to": 232360
      },
      "text": "مش إن أنا أقعد أستعمل الحاجات دي كلها. فكرة الـ Container إن أنا"
