    {
      "timestamps": {
        "from": "00:02:24,660",
        "to": "00:02:30,720"
      },
      "offsets": {
        "from": 144660,
        "to": 150720
      },
      "text": "حصل لها Terminate الـ Container كله ملوش لازمة. واحدة واحدة تاني كده"
