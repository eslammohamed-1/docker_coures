      "timestamps": {
        "from": "00:03:52,360",
        "to": "00:03:55,960"
      },
      "offsets": {
        "from": 232360,
        "to": 235960
      },
      "text": "بعمل Bundle للـ Application بالـ requirements دي بس، إن أنا يبقى عندي الـ Container"
