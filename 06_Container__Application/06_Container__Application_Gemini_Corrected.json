    {
      "timestamps": {
        "from": "00:02:53,880",
        "to": "00:02:59,460"
      },
      "offsets": {
        "from": 173880,
        "to": 179460
      },
      "text": "الـ Apps بتاعتك، وممكن يكون فيها Apps تانية. تمام؟ أي App تانية إنت"
