GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_MODEL_FALLBACK=gemini-3.1-pro-preview-customtools
# Free-tier fallback (comma-separated) — updated model names
GEMINI_MODEL_FREE_TIER=gemini-2.5-flash,gemini-3-flash-preview,gemini-3.5-flash
# true = skip Pro models entirely
GEMINI_USE_FREE_TIER_ONLY=false
FORMAT_CHAPTER_DELAY_SEC=15
FORMAT_CHUNK_SIZE=80
FORMAT_CHUNK_DELAY_SEC=5
# auto_transcribe.py --gemini chunking (falls back to FORMAT_* if unset)
GEMINI_CHUNK_SIZE=80
GEMINI_CHUNK_DELAY_SEC=5

# auto_transcribe.py Whisper reliability
WHISPER_AUDIO_CHUNK_SEC=300
WHISPER_RETRY_CHUNK_SEC=180
WHISPER_MAX_CHUNK_RETRIES=1
WHISPER_REPEAT_RATIO=0.15
WHISPER_REPEAT_STREAK=8
WHISPER_REPEATED_WORD_LIMIT=12
WHISPER_COLLAPSE_REPEATED_WORDS=true
WHISPER_ENGLISH_DRIFT_RATIO=0.65
WHISPER_MAX_CONTEXT=0
WHISPER_MAX_LEN=180
WHISPER_SUPPRESS_NST=true
WHISPER_VAD=false
